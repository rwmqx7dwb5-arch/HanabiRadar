# Mac-free TestFlight release lane.
#
# Everything here runs on the GitHub Actions macOS runner — no local Mac is needed. The
# App Store Connect API key (.p8) authenticates every step (no Apple ID password / 2FA),
# and `match` creates/fetches the distribution certificate + App Store profile headlessly.
#
# All secrets come from the environment (GitHub Actions secrets); see
# Docs/TESTFLIGHT_CLOUD_RELEASE.md for the exact list and how to obtain each one. The
# .xcodeproj is generated by XcodeGen in the workflow before this lane runs.

default_platform(:ios)

APP_ID = ENV["APP_IDENTIFIER"] || "com.example.hanabiradar"
XCODEPROJ = "HanabiRadar.xcodeproj"

platform :ios do
  desc "Build a signed Release archive and upload it to TestFlight (Mac-free)."
  lane :beta do
    # Creates a temporary keychain on CI so `match` can install the signing identity.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true
    )

    # Fetch (or create, on first run) the Apple Distribution cert + App Store profile.
    # readonly:false lets the very first run generate them; flip to true once they exist.
    match(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: api_key,
      readonly: false
    )

    profile_name = "match AppStore #{APP_ID}"
    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    build_app(
      project: XCODEPROJ,
      scheme: "HanabiRadar",
      configuration: "Release",
      export_method: "app-store",
      # The generated project builds unsigned (CODE_SIGNING_ALLOWED=NO) for the test CI;
      # override signing here so the release archive is signed with the match identity.
      xcargs: [
        "PRODUCT_BUNDLE_IDENTIFIER=#{APP_ID}",
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "CODE_SIGNING_ALLOWED=YES",
        "CODE_SIGNING_REQUIRED=YES",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY=Apple Distribution",
        "PROVISIONING_PROFILE_SPECIFIER=#{profile_name}",
        "DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']}"
      ].join(" "),
      export_options: {
        provisioningProfiles: { APP_ID => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
